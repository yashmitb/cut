# --- Gemini (Google AI Studio) ---
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here
# Vision model for food photo analysis. Swap to a newer model anytime.
GEMINI_MODEL=gemini-2.5-pro
# Optional: a separate (faster/cheaper) model for text chat & manual entry.
# Defaults to GEMINI_MODEL if unset.
# GEMINI_TEXT_MODEL=gemini-2.5-flash

# --- Database (any Postgres works: Neon, Supabase, Vercel Postgres) ---
# Neon/Supabase/Vercel give you a connection string like:
#   postgres://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
