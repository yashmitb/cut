# --- Gemini (Google AI Studio) ---
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here
# Vision model for food photo analysis. Swap to a newer model anytime.
GEMINI_MODEL=gemini-2.5-flash
# Optional: a separate (faster/cheaper) model for text chat & manual entry.
# Defaults to GEMINI_MODEL if unset.
# GEMINI_TEXT_MODEL=gemini-2.5-flash

# --- Database (any Postgres works: Neon, Supabase, Vercel Postgres) ---
# Neon/Supabase/Vercel give you a connection string like:
#   postgres://user:pass@host/dbname?sslmode=require
# On Vercel's Supabase integration this is provided as POSTGRES_URL automatically.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Supabase Auth (enables multi-user OAuth sign-in) ---
# From Supabase: Project Settings -> Data API / API Keys.
# The Vercel Supabase integration sets these for you automatically.
# If BOTH are unset, the app runs in local single-user mode (no sign-in).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_anon_key

# --- Server-Side Rendering (Optional) ---
# Absolute base URL of the site, used to prefix relative fetches during server-side pre-rendering on Vercel.
# NEXT_PUBLIC_BASE_URL=https://cut-eta.vercel.app

